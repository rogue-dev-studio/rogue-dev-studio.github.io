#!/bin/sh
# Remove AI-agent attribution trailers (publisher identity = human only).
MSG_FILE="$1"
if [ ! -f "$MSG_FILE" ]; then
  exit 0
fi

HOOK_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
if command -v node >/dev/null 2>&1; then
  node "$HOOK_DIR/strip-agent-trailers.mjs" < "$MSG_FILE" > "${MSG_FILE}.strip" && mv "${MSG_FILE}.strip" "$MSG_FILE"
fi

exit 0
