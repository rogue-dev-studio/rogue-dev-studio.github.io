#!/bin/sh
# Remove ALL Co-authored-by / AI attribution trailers (owner-only publisher).
MSG_FILE="$1"
if [ ! -f "$MSG_FILE" ]; then
  exit 0
fi

HOOK_DIR=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
if command -v node >/dev/null 2>&1; then
  node "$HOOK_DIR/strip-agent-trailers.mjs" < "$MSG_FILE" > "${MSG_FILE}.strip" && mv "${MSG_FILE}.strip" "$MSG_FILE"
else
  TMP_FILE="${MSG_FILE}.strip"
  awk '
    BEGIN { IGNORECASE=1 }
    /^Co-authored-by:/ { next }
    /^Made-with:/ { next }
    /^Made with Cursor/ { next }
    /^Generated-by:/ { next }
    /^Generated by / { next }
    /cursoragent@/ { next }
    { print }
  ' "$MSG_FILE" > "$TMP_FILE" && mv "$TMP_FILE" "$MSG_FILE"
fi

exit 0
